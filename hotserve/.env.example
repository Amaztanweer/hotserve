# ─────────────────────────────────────────────────────────────
# HotServe — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=your-django-secret-key
DEBUG=False  
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.onrender.com

# ── Database (PostgreSQL) ─────────────────────────────────────
DB_NAME=hotserve_db
DB_USER=hotserve_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Razorpay ─────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=yourid
RAZORPAY_KEY_SECRET=yourpass

# Platform commission (percentage kept by HotServe)
PLATFORM_COMMISSION_PERCENT=10

# ── Email ────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=yourpassword
ALLOWED_COLLEGE_DOMAINS=gmail.com

# ── CORS (for API clients) ────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
